
.UCenter-bg {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    color: #fff;
}

.cu-list.menu {
    margin-left: 30rpx;
    margin-right: 30rpx;
    border-radius: 20rpx;
}

.diet-analysis-section {
    padding: 0 20rpx 20rpx;
}

.section-header {
    display: flex;
    align-items: center;
    padding: 20rpx 10rpx;
    margin-bottom: 20rpx;
}

.section-header text:first-child {
    font-size: 40rpx;
    color: #4CAF50;
    margin-right: 12rpx;
}

.section-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-right: auto;
}

.section-date {
    font-size: 24rpx;
    color: #999;
}

.summary-card,
.chart-card,
.daily-card,
.health-card {
    padding: 30rpx;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.summary-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20rpx;
}

.summary-item {
    text-align: center;
    padding: 24rpx 16rpx;
    background: linear-gradient(135deg, #f5f5f5 0%, #fafafa 100%);
    border-radius: 12rpx;
}

.summary-value {
    font-size: 36rpx;
    font-weight: bold;
    margin-bottom: 8rpx;
}

.summary-label {
    font-size: 24rpx;
    color: #666;
    margin-bottom: 6rpx;
}

.summary-avg {
    font-size: 22rpx;
    color: #999;
}

.text-orange { color: #FF9800; }
.text-blue { color: #2196F3; }
.text-green { color: #4CAF50; }
.text-purple { color: #9C27B0; }

.card-title {
    display: flex;
    align-items: center;
    font-size: 30rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 24rpx;
    padding-bottom: 20rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

.card-title text:first-child {
    font-size: 36rpx;
    margin-right: 12rpx;
    color: #FFA500;
}

.recommend-title text:first-child {
    color: #4CAF50;
}

.chart-wrapper {
    width: 100%;
    height: 400rpx;
}

.weekly-chart {
    width: 100%;
    height: 100%;
}

.daily-list {
    max-height: 800rpx;
    overflow-y: auto;
}

.daily-item {
    padding: 24rpx 0;
    border-bottom: 1rpx solid #f5f5f5;
}

.daily-item:last-child {
    border-bottom: none;
}

.daily-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16rpx;
}

.daily-date {
    display: flex;
    flex-direction: column;
}

.date-text {
    font-size: 28rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 4rpx;
}

.date-week {
    font-size: 22rpx;
    color: #999;
}

.daily-stats {
    display: flex;
    align-items: center;
    gap: 16rpx;
}

.order-count {
    padding: 4rpx 12rpx;
    background-color: #E3F2FD;
    color: #2196F3;
    font-size: 22rpx;
    border-radius: 12rpx;
}

.calories {
    font-size: 28rpx;
    font-weight: bold;
    color: #FF9800;
}

.daily-nutrition {
    margin-top: 12rpx;
}

.nutrition-bar {
    display: flex;
    gap: 8rpx;
    height: 40rpx;
    border-radius: 8rpx;
    overflow: hidden;
    background-color: #f5f5f5;
}

.bar-item {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: width 0.3s ease;
    min-width: 60rpx;
}

.bar-item.protein {
    background: linear-gradient(90deg, #2196F3, #64B5F6);
}

.bar-item.fat {
    background: linear-gradient(90deg, #4CAF50, #81C784);
}

.bar-item.carb {
    background: linear-gradient(90deg, #9C27B0, #BA68C8);
}

.bar-label {
    font-size: 20rpx;
    color: #fff;
    font-weight: bold;
    white-space: nowrap;
}

.daily-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 30rpx 0;
    color: #ccc;
}

.empty-icon {
    font-size: 40rpx;
    margin-right: 12rpx;
}

.empty-text {
    font-size: 26rpx;
}

.recommend-list {
    max-height: 500rpx;
    overflow-y: auto;
}

.recommend-item {
    display: flex;
    align-items: flex-start;
    padding: 16rpx 0;
    border-bottom: 1rpx solid #E8F5E9;
}

.recommend-item:last-child {
    border-bottom: none;
}

.recommend-icon {
    width: 40rpx;
    height: 40rpx;
    background-color: #E8F5E9;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 16rpx;
    flex-shrink: 0;
}

.recommend-icon text {
    font-size: 24rpx;
    color: #4CAF50;
}

.recommend-text {
    flex: 1;
    font-size: 26rpx;
    color: #666;
    line-height: 1.6;
}
